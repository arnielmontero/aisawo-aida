# Turso (hosted SQLite) — get these from turso.tech dashboard
TURSO_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# OpenRouter keys
# Primary key stored in Turso DB (set via /admin panel)
# Backup key used automatically if primary returns 401
OPENROUTER_BACKUP_KEY=sk-or-v1-your-backup-key-here

# Admin panel password — choose any strong string
ADMIN_TOKEN=change-this-to-a-strong-secret
